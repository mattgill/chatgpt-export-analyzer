<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width,initial-scale=1">
  <title>ChatGPT Export Analytics</title>
  <style>
    body{font-family:system-ui,sans-serif;margin:auto;max-width:1280px;padding:2rem;background:#f8fafc;color:#172033}h1{margin-bottom:.2rem}.sub{color:#60708c}.cards{display:grid;grid-template-columns:repeat(auto-fit,minmax(170px,1fr));gap:1rem;margin:1.5rem 0}.card,section{background:white;border-radius:12px;padding:1rem 1.25rem;box-shadow:0 1px 4px #dce3ed}.card span{display:block;color:#60708c;font-size:.82rem}.card strong{font-size:1.5rem}section{margin:1.25rem 0;overflow:auto}table{border-collapse:collapse;width:100%}th,td{text-align:left;padding:.65rem;border-bottom:1px solid #e4e8ef}th{color:#536178}td.num{text-align:right}.chart{min-width:640px}
  </style>
</head>
<body>
  <h1>ChatGPT Export Analytics</h1>
  <p class="sub">Offline token and API cost estimates. Costs use the first configured model and only API-equivalent visible message text; reasoning tokens, cached input, and internal prompts are not included.</p>

  <section>
    <h2>Executive Summary</h2>
    <div class="cards">
      <div class="card"><span>Conversations</span><strong>{{ totals.conversations }}</strong></div>
      <div class="card"><span>Prompts / Replies</span><strong>{{ totals.prompts }} / {{ totals.replies }}</strong></div>
      <div class="card"><span>Input Tokens</span><strong>{{ '{:,}'.format(totals.input_tokens) }}</strong></div>
      <div class="card"><span>Output Tokens</span><strong>{{ '{:,}'.format(totals.output_tokens) }}</strong></div>
      <div class="card"><span>Lifetime Estimated Cost</span><strong>${{ '%.2f'|format(totals.cost) }}</strong></div>
    </div>
  </section>

  <section>
    <h2>Export Content Inventory</h2>
    <p>API-equivalent text is used for all token and cost totals. Retained recap text and internal artifacts describe the broader export, but are never included in estimated API spend.</p>
    <table>
      <tr><th>Category</th><th>Nodes</th><th>Tokens</th><th>Cost treatment</th></tr>
      <tr><td>API-equivalent visible text</td><td>{{ totals.prompts + totals.replies }}</td><td>{{ '{:,}'.format(inventory.api_total_tokens) }}</td><td>Included</td></tr>
      <tr><td>Retained reasoning recaps</td><td>{{ inventory.recap_nodes }}</td><td>{{ '{:,}'.format(inventory.recap_tokens) }}</td><td>Non-billable context</td></tr>
      <tr><td>Structured internal thoughts</td><td>{{ inventory.internal_artifact_nodes }}</td><td>Not tokenized</td><td>Excluded artifact</td></tr>
    </table>
  </section>

  <section>
    <h2>Cost by Model</h2>
    <table><tr><th>Model</th><th>Input Tokens</th><th>Output Tokens</th><th>Estimated Cost</th></tr>{% for row in summary %}<tr><td>{{ row.model }}</td><td>{{ '{:,}'.format(row.input_tokens) }}</td><td>{{ '{:,}'.format(row.output_tokens) }}</td><td>${{ '%.2f'|format(row.estimated_cost) }}</td></tr>{% endfor %}</table>
  </section>

  {% if reasoning_scenario %}
  <section>
    <h2>What-if Reasoning Overhead</h2>
    <p>This is a user-supplied scenario, not a measured value from the export. It assumes {{ reasoning_scenario.output_multiplier }} hidden reasoning tokens per visible assistant-output token: {{ '{:,}'.format(reasoning_scenario.estimated_reasoning_tokens) }} additional output tokens.</p>
    <table><tr><th>Model</th><th>Visible-text Estimate</th><th>Scenario Estimate</th><th>Additional Cost</th></tr>{% for row in reasoning_scenario.rows %}<tr><td>{{ row.model }}</td><td>${{ '%.2f'|format(row.visible_cost) }}</td><td>${{ '%.2f'|format(row.scenario_cost) }}</td><td>${{ '%.2f'|format(row.additional_cost) }}</td></tr>{% endfor %}</table>
  </section>
  {% endif %}

  <section><h2>Monthly Spending</h2><div class="chart">{{ charts.monthly_cost|safe }}</div></section>
  <section><h2>Monthly Token Usage</h2><div class="chart">{{ charts.monthly_tokens|safe }}</div></section>
  <section><h2>Cumulative Token Usage</h2><div class="chart">{{ charts.cumulative_tokens|safe }}</div></section>
  <section><h2>Cumulative Estimated Spend</h2><div class="chart">{{ charts.cumulative_cost|safe }}</div></section>
  <section><h2>Conversation Size Distribution</h2><div class="chart">{{ charts.histogram|safe }}</div></section>
  <section><h2>Monthly Heatmap</h2><div class="chart">{{ charts.heatmap|safe }}</div></section>

  <section>
    <h2>Additional Insights</h2>
    <p>Average conversation: {{ '%.0f'|format(metrics.average_conversation_tokens) }} tokens · Median: {{ '%.0f'|format(metrics.median_conversation_tokens) }} · Longest: {{ metrics.longest_conversation }} · Longest prompt: {{ metrics.longest_prompt_characters }} characters · Longest reply: {{ metrics.longest_reply_characters }} characters</p>
    <h3>Top 10 Days</h3>
    <table><tr><th>Date</th><th>Tokens</th><th>Prompts</th><th>Replies</th></tr>{% for day in metrics.top_days %}<tr><td>{{ day.day }}</td><td>{{ '{:,}'.format(day.total_tokens) }}</td><td>{{ day.prompts }}</td><td>{{ day.assistant_replies }}</td></tr>{% else %}<tr><td colspan="4">No dated messages were available.</td></tr>{% endfor %}</table>
  </section>

  <section>
    <h2>Top Conversations</h2>
    <table id="conversations"><tr><th onclick="sortTable(0)">Title</th><th onclick="sortTable(1)">Date</th><th onclick="sortTable(2)">Tokens</th><th onclick="sortTable(3)">Estimated Cost ({{ primary_model }})</th><th onclick="sortTable(4)">Turns</th></tr>{% for row in conversations %}<tr><td>{{ row.title }}</td><td>{{ row.first_message_date[:10] }}</td><td>{{ '{:,}'.format(row.total_tokens) }}</td><td>${{ '%.2f'|format(row.estimated_cost) }}</td><td>{{ row.user_turns + row.assistant_turns }}</td></tr>{% endfor %}</table>
    <p class="sub">Click a column heading to sort.</p>
  </section>
  <script>function sortTable(n){const t=document.getElementById('conversations'),a=[...t.rows].slice(1);const numeric=n>1;a.sort((x,y)=>{let p=x.cells[n].innerText,q=y.cells[n].innerText;if(numeric){p=parseFloat(p.replace(/[^0-9.-]/g,''));q=parseFloat(q.replace(/[^0-9.-]/g,''));return q-p}return p.localeCompare(q)});a.forEach(r=>t.appendChild(r))}</script>
</body>
</html>
